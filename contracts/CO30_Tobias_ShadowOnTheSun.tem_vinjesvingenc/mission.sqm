				condition="( " \n "    damage convoy_1 > 0.01 " \n " || damage convoy_2 > 0.01 " \n " || damage convoy_3 > 0.01 " \n " || damage convoy_4 > 0.01 " \n ") " \n "|| " \n "( " \n "    { " \n "        behaviour _x == ""COMBAT"" " \n "    } count (crew convoy_1 + crew convoy_2 + crew convoy_3 + crew convoy_4) > 0 " \n ") " \n "";
				onActivation="private _dropPos = convoy_3 getPos [random 150, random 360]; " \n "private _heliGrp = group heli_1; " \n " " \n "private _wpUnload = _heliGrp addWaypoint [_dropPos, 0]; " \n "_wpUnload setWaypointType ""TR UNLOAD""; " \n "_wpUnload setWaypointBehaviour ""CARELESS""; " \n "_wpUnload setWaypointSpeed ""FULL""; " \n "_wpUnload setWaypointCombatMode ""BLUE""; " \n " " \n "private _wpLoiter = _heliGrp addWaypoint [_dropPos, 0]; " \n "_wpLoiter setWaypointType ""LOITER""; " \n "_wpLoiter setWaypointLoiterType ""CIRCLE_L""; " \n "_wpLoiter setWaypointLoiterRadius 300; " \n "_wpLoiter setWaypointBehaviour ""CARELESS""; " \n "_wpLoiter setWaypointSpeed ""FULL""; " \n "_wpLoiter setWaypointCombatMode ""BLUE""; " \n " " \n "{ " \n "    private _grp = _x; " \n "    private _wp = _grp addWaypoint [getPos convoy_3, 0]; " \n "    _wp setWaypointType ""MOVE""; " \n "    _wp setWaypointBehaviour ""COMBAT""; " \n "    _wp setWaypointSpeed ""FULL""; " \n "} forEach [qrf_1, qrf_2]; " \n "";
				sizeA=0;
				sizeB=0;
				timeout[]={240,300,360};
				repeatable=1;
				activationType="GUER D";
				isServerOnly=1;
				triggerInterval=2;
			};
